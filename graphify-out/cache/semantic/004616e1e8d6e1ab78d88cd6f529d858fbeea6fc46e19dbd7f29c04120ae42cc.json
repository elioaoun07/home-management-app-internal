{"nodes": [{"id": "c03_notification_registry", "label": "Notification Registry", "file_type": "document", "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "source_url": null, "captured_at": "2026-07-10", "author": "Elio", "contributor": null, "rationale": "registry.tsx became the TypeScript-side source of truth for routes, actions, icons, class, calendar sync, takeover eligibility, and retention; the service worker remains separate."}, {"id": "c03_alerts_page_unification", "label": "Unified realtime alerts page", "file_type": "document", "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "source_url": null, "captured_at": "2026-07-10", "author": "Elio", "contributor": null, "rationale": "The alerts page now shares the bell's data source, updates in realtime, groups by date and group_key, and offers system, scheduled, and unread filters."}, {"id": "c03_critical_alert_gate", "label": "Critical Alert Gate", "file_type": "document", "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "source_url": null, "captured_at": "2026-07-10", "author": "Elio", "contributor": null, "rationale": "A globally mounted full-screen takeover provides a third attention layer for unacted high or urgent eligible alerts."}, {"id": "c03_gcal_backup_sync", "label": "Google Calendar backup sync", "file_type": "document", "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "source_url": null, "captured_at": "2026-07-10", "author": "Elio", "contributor": null, "rationale": "One-way sync for scheduled items was wired into actual browser-side mutations, moved bookkeeping behind an access-gated admin client, and was live-verified for sync and delete."}, {"id": "c03_quick_action_schema_fix", "label": "Notification quick-action schema correction", "file_type": "document", "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "source_url": null, "captured_at": "2026-07-10", "author": "Elio", "contributor": null, "rationale": "The actions endpoint had been writing non-existent columns, so Done, Snooze, Confirm, and Dismiss silently failed until the column mapping was corrected."}, {"id": "c03_notification_maturity_snapshot", "label": "Notifications maturity snapshot", "file_type": "document", "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "Maturity scoreboard", "source_url": null, "captured_at": "2026-07-10", "author": "Elio", "contributor": null, "rationale": "Overall maturity rose to about 5.8 after registry, alerts, action, critical-gate, and calendar work, while bell calm, drawer density, and delivery policy remain open."}], "edges": [{"source": "c03_notification_registry", "target": "c03_dual_notification_routers", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "weight": 1.0}, {"source": "c03_alerts_page_unification", "target": "c03_notification_registry", "relation": "depends_on", "confidence": "INFERRED", "confidence_score": 0.82, "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "What moved since 2026-07-02", "weight": 1.0}, {"source": "c03_alerts_page_unification", "target": "c03_notification_grouping", "relation": "depends_on", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ERA Notes/10 - Project Management/Notifications & Alerts/FABLED 2/_index.md", "source_location": "