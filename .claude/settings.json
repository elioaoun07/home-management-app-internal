{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-ui-dir.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-copilot.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/update-atlas.sh"
          }
        ]
      }
    ]
  }
}
