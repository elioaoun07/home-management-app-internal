export function isOfflineError(err: unknown): err is OfflineError {
  if (!err) return false;
  if (err instanceof OfflineError) return true;
  if (err instanceof TypeError) return true; // "Failed to fetch"
  if (err instanceof DOMException && err.name === "AbortError") return true;
  if (
    err instanceof Error &&
    /network|failed to fetch|load failed/i.test(err.message)
  )
    return true;
  return false; // ← What if err is {name: "TypeError", message: "..."} ?
}
